<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>scrim</title>
<style>
  body { font-family: system-ui, sans-serif; margin: 2rem; color: #222; }
  h1 { font-size: 1.25rem; }
  table { border-collapse: collapse; width: 100%; max-width: 60rem; }
  th, td { text-align: left; padding: 0.4rem 0.75rem; border-bottom: 1px solid #ddd; }
  th { color: #666; font-weight: 600; }
  a { color: #0645ad; }
  .empty { color: #666; }
  footer { margin-top: 2rem; color: #999; font-size: 0.85rem; }
</style>
</head>
<body>
<h1>scrim</h1>
{{if .Canvases}}
<table>
  <thead><tr><th>ID</th><th>Title</th><th>Last modified</th></tr></thead>
  <tbody>
  {{range .Canvases}}
    <tr>
      <td><a href="{{.URL}}">{{.ID}}</a></td>
      <td>{{if .Title}}{{.Title}}{{else}}&mdash;{{end}}</td>
      <td>{{.ModTime}}</td>
    </tr>
  {{end}}
  </tbody>
</table>
{{else}}
<p class="empty">No canvases yet. Use <code>scrim add &lt;id&gt;</code> to create one.</p>
{{end}}
<footer>scrim {{.Version}}</footer>
</body>
</html>
